# ============================================
# CONFIGURATION SUPABASE
# ============================================
# URL de votre projet Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Clé publique (anon key) - Safe côté client
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Clé service (service role key) - UNIQUEMENT côté serveur
SUPABASE_SERVICE_KEY=your-service-role-key-here

# ============================================
# CONFIGURATION MISTRAL AI
# ============================================
# Clé API Mistral (obtenir sur https://console.mistral.ai)
MISTRAL_API_KEY=your-mistral-api-key-here

# ============================================
# CONFIGURATION APPLICATION
# ============================================
# URL de base de l'application
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Mode de l'application (development, production)
NODE_ENV=development

# ============================================
# CONFIGURATION EMAIL (optionnel)
# ============================================
# Pour les notifications et emails transactionnels
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# ============================================
# CONFIGURATION ANALYTICS (optionnel)
# ============================================
# Google Analytics
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# Posthog Analytics
NEXT_PUBLIC_POSTHOG_KEY=phc_xxxxxxxxxxxxx
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# ============================================
# CONFIGURATION SÉCURITÉ
# ============================================
# Secret pour JWT (générer avec: openssl rand -base64 32)
JWT_SECRET=your-jwt-secret-here

# Secret pour les cookies
COOKIE_SECRET=your-cookie-secret-here

# ============================================
# LIMITES ET QUOTAS
# ============================================
# Quotas journaliers par modèle (optionnel, par défaut dans le code)
MAGISTRAL_MEDIUM_DAILY_QUOTA=60
MISTRAL_MEDIUM_3_DAILY_QUOTA=300
MISTRAL_SMALL_DAILY_QUOTA=1000

# ============================================
# NOTES IMPORTANTES
# ============================================
# 1. Ne JAMAIS commiter ce fichier avec des vraies clés
# 2. Copier ce fichier vers .env.local et remplir les valeurs
# 3. Les variables NEXT_PUBLIC_* sont exposées au client
# 4. Les autres variables sont uniquement côté serveur
# 5. Générer des secrets sécurisés pour production