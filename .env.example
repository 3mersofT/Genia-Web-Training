# ===========================================================
# GENIA Web Training — Environment Variables
# ===========================================================
# Copy this file to .env.local and fill in the values.
#   cp .env.example .env.local
#
# Variables marked [REQUIRED] must be set for the app to work.
# Variables marked [OPTIONAL] have sensible defaults.
# ===========================================================

# -----------------------------------------------------------
# SUPABASE [REQUIRED]
# -----------------------------------------------------------
# Get these from: Supabase Dashboard > Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Service role key — server-side only, never expose to client
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Direct database connection string — used by npm run db:setup/db:reset
# Get from: Supabase Dashboard > Settings > Database > Connection string > URI
DATABASE_URL=postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres

# -----------------------------------------------------------
# LLM API KEYS [at least one REQUIRED] — server-side only
# -----------------------------------------------------------
# Never use NEXT_PUBLIC_ prefix for these keys.
# They are only accessed in API routes (src/app/api/).

# Mistral AI — https://console.mistral.ai
MISTRAL_API_KEY=your-mistral-api-key-here

# OpenAI — https://platform.openai.com/api-keys
OPENAI_API_KEY=your-openai-api-key-here

# Anthropic Claude — https://console.anthropic.com
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# DeepSeek — https://platform.deepseek.com
DEEPSEEK_API_KEY=your-deepseek-api-key-here

# -----------------------------------------------------------
# APPLICATION [OPTIONAL]
# -----------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=GENIA
NODE_ENV=development

# Feature flag: enable demo/test accounts (NEVER in production)
ENABLE_DEMO_ACCOUNTS=false

# Feature flags for optional modules
NEXT_PUBLIC_ENABLE_PWA=true
NEXT_PUBLIC_ENABLE_GENIA_CHAT=true
NEXT_PUBLIC_ENABLE_ANALYTICS=false

# -----------------------------------------------------------
# DATABASE SEED [OPTIONAL]
# -----------------------------------------------------------
# UUID of the auth.users entry to promote to admin role.
# Find it in Supabase Dashboard > Authentication > Users.
ADMIN_USER_ID=

# -----------------------------------------------------------
# LLM QUOTAS [OPTIONAL] — defaults defined in code
# -----------------------------------------------------------
MAGISTRAL_MEDIUM_DAILY_QUOTA=60
MISTRAL_MEDIUM_3_DAILY_QUOTA=300
MISTRAL_SMALL_DAILY_QUOTA=1000

# -----------------------------------------------------------
# RATE LIMITING [OPTIONAL] — Upstash Redis
# -----------------------------------------------------------
# For distributed rate limiting on Vercel (serverless).
# Without these, an in-memory Map is used (resets on cold start).
# UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
# UPSTASH_REDIS_REST_TOKEN=your-upstash-token-here

# -----------------------------------------------------------
# EMAIL [OPTIONAL] — for digest notifications
# -----------------------------------------------------------
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password

# -----------------------------------------------------------
# ANALYTICS [OPTIONAL]
# -----------------------------------------------------------
# NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
# NEXT_PUBLIC_POSTHOG_KEY=phc_xxxxxxxxxxxxx
# NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# -----------------------------------------------------------
# SECURITY [OPTIONAL]
# -----------------------------------------------------------
# JWT_SECRET=your-jwt-secret-here
# COOKIE_SECRET=your-cookie-secret-here

# -----------------------------------------------------------
# TESTING [OPTIONAL]
# -----------------------------------------------------------
# PLAYWRIGHT_TEST_BASE_URL=http://localhost:3000

# ===========================================================
# IMPORTANT NOTES
# ===========================================================
# 1. NEVER commit .env.local with real keys
# 2. Variables prefixed NEXT_PUBLIC_ are exposed to the browser
# 3. All other variables are server-side only
# 4. Generate secrets with: openssl rand -base64 32
